# Problem: Find Maximum in Array
# Platform: Practice
# Approach: Linear Scan
# Time Complexity: O(n)
# Space Complexity: O(1)

def find_max_value(arr):
    max_val = arr[0]   # assume first element is max
    
    for num in arr:
        if num > max_val:
            max_val = num
            
    return max_val


arr = [1, 3, 7, 9]
print(find_max_value(arr))
